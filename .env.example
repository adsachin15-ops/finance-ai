# ============================================================
# Finance-AI Environment Template
# ============================================================

APP_ENV=development
DEBUG=false

HOST=0.0.0.0
PORT=8000

LOG_LEVEL=INFO
LOG_FORMAT=console

# Database
DB_PATH=database/finance.db
GUEST_DB_PATH=

# Security
SECRET_KEY=change-me-in-production
DB_ENCRYPTION_KEY=change-me-in-production

# Upload limits
MAX_FILE_SIZE_MB=10

# Allowed extensions
ALLOWED_EXTENSIONS=csv,xlsx,pdf
